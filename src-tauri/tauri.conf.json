{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StewardAuth",
  "version": "0.1.1",
  "identifier": "com.stewardauth.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StewardAuth",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "public.app-category.utilities",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist",
      "exceptionDomain": null,
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2OEI0NTBBOEY0MzQ0QjcKUldTM1JFT1BDa1dMaGpNc24zT09lKzRHNzhtV1JISDdpZEdxTE8xdkI5czE0ZTIxNWtjQldMUGcK",
      "endpoints": [
        "https://github.com/shinyawave/stewardauth/releases/latest/download/latest.json"
      ]
    }
  }
}
